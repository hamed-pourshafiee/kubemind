---
import { education } from "../data/resume";
---

<section id="education" class="py-24 px-4 bg-surface-900/30">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-sm font-semibold text-primary-400 uppercase tracking-widest mb-2">
        Background
      </h2>
      <h3 class="text-3xl md:text-4xl font-bold text-surface-50">
        Education
      </h3>
    </div>

    <div class="max-w-xl mx-auto">
      <div class="p-8 rounded-2xl bg-surface-800/50 border border-surface-700/50 hover:border-primary-500/30 transition-all text-center">
        <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-primary-600/20 flex items-center justify-center">
          <svg class="w-8 h-8 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
          </svg>
        </div>
        <h4 class="text-xl font-bold text-surface-50 mb-2">
          {education.degree}
        </h4>
        <p class="text-primary-400/80 font-medium mb-2">
          {education.university}
        </p>
        <p class="text-sm text-surface-100/50">{education.location}</p>
      </div>
    </div>
  </div>
</section>
