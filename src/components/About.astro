---
import { personalInfo } from "../data/resume";
---

<section id="about" class="py-24 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="max-w-3xl mx-auto">
      <div>
        <h2 class="text-sm font-semibold text-primary-400 uppercase tracking-widest mb-2">
          About Me
        </h2>
        <h3 class="text-3xl md:text-4xl font-bold text-surface-50 mb-6">
          Turning complex problems into elegant solutions
        </h3>
        <p class="text-lg text-surface-100/70 leading-relaxed mb-6">
          {personalInfo.summary}
        </p>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
          <div class="p-4 rounded-xl bg-surface-800/50 border border-surface-700/50">
            <div class="text-2xl font-bold text-primary-400">8+</div>
            <div class="text-sm text-surface-100/50">Years Experience</div>
          </div>
          <div class="p-4 rounded-xl bg-surface-800/50 border border-surface-700/50">
            <div class="text-2xl font-bold text-primary-400">9</div>
            <div class="text-sm text-surface-100/50">Companies</div>
          </div>
          <div class="p-4 rounded-xl bg-surface-800/50 border border-surface-700/50">
            <div class="text-2xl font-bold text-primary-400">20+</div>
            <div class="text-sm text-surface-100/50">Technologies</div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
