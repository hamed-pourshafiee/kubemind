---
import { experiences } from "../data/resume";
---

<section id="experience" class="py-24 px-4 bg-surface-900/30">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-sm font-semibold text-primary-400 uppercase tracking-widest mb-2">
        Career Path
      </h2>
      <h3 class="text-3xl md:text-4xl font-bold text-surface-50">
        Professional Experience
      </h3>
    </div>

    <div class="relative">
      <div class="absolute left-0 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-primary-600/50 via-accent-500/30 to-transparent md:-translate-x-px"></div>

      {experiences.map((exp, i) => (
        <div class={`relative flex flex-col md:flex-row gap-8 mb-12 last:mb-0 ${i % 2 === 0 ? "md:flex-row-reverse" : ""}`}>
          <div class="absolute left-0 md:left-1/2 w-3 h-3 bg-primary-500 rounded-full border-2 border-surface-950 -translate-x-[5px] md:-translate-x-[6px] mt-6 z-10"></div>

          <div class="md:w-1/2"></div>

          <div class="ml-6 md:ml-0 md:w-1/2 group">
            <div class={`p-6 rounded-2xl bg-surface-800/50 border border-surface-700/50 hover:border-primary-500/30 transition-all hover:shadow-lg hover:shadow-primary-900/20 ${i % 2 === 0 ? "md:mr-8" : "md:ml-8"}`}>
              <div class="flex items-start justify-between mb-3">
                <div>
                  <h4 class="text-lg font-bold text-surface-50 group-hover:text-primary-400 transition-colors">
                    {exp.title}
                  </h4>
                  <p class="text-primary-400/80 font-medium">{exp.company}</p>
                </div>
              </div>
              <div class="flex flex-wrap gap-2 mb-4 text-xs text-surface-100/50">
                <span class="px-2 py-1 rounded-md bg-surface-700/50">{exp.period}</span>
                <span class="px-2 py-1 rounded-md bg-surface-700/50">{exp.location}</span>
              </div>
              <ul class="space-y-2">
                {exp.highlights.map((h) => (
                  <li class="flex items-start gap-2 text-sm text-surface-100/70">
                    <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary-500/60 flex-shrink-0"></span>
                    {h}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
